# =============================================================================
# ShipFlow AI — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env or .env.local — they are git-ignored.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL via Neon / AWS RDS / Local Docker)
# -----------------------------------------------------------------------------

# Primary connection URL (pooled — used by Prisma in app code)
DATABASE_URL=postgresql://shipflow:shipflow_secret@localhost:5432/shipflow_db

# Direct / unpooled URL (used by Prisma Migrate only — required for migrations)
DIRECT_URL=postgresql://shipflow:shipflow_secret@localhost:5432/shipflow_db

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------

NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# BETTER AUTH
# =============================================================================
# Generate BETTER_AUTH_SECRET with: openssl rand -base64 32
# This key encrypts sessions and must be kept secret.
# =============================================================================

# Random 32+ character secret for session encryption (REQUIRED)
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=your-super-secret-key-here-min-32-chars

# Optional: Override default auth URL (defaults to NEXT_PUBLIC_APP_URL)
# BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth Application
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google OAuth Application (optional)
# Create at: https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# -----------------------------------------------------------------------------
# AI PROVIDERS
# -----------------------------------------------------------------------------

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Google AI (Gemini)
GOOGLE_AI_API_KEY=AIza...

# -----------------------------------------------------------------------------
# GITHUB APP INTEGRATION
# -----------------------------------------------------------------------------

# GitHub App credentials (for Octokit)
GITHUB_APP_ID=your_github_app_id
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret

# -----------------------------------------------------------------------------
# INNGEST (Background Jobs / Event Queue)
# -----------------------------------------------------------------------------

INNGEST_EVENT_KEY=your_inngest_event_key
INNGEST_SIGNING_KEY=signkey-...

# -----------------------------------------------------------------------------
# PAYMENTS (Razorpay)
# -----------------------------------------------------------------------------

RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# -----------------------------------------------------------------------------
# EMAIL (Resend)
# -----------------------------------------------------------------------------

RESEND_API_KEY=re_...
EMAIL_FROM=noreply@shipflow.ai

# -----------------------------------------------------------------------------
# STORAGE (Uploadthing / S3-compatible)
# -----------------------------------------------------------------------------

UPLOADTHING_SECRET=sk_live_...
UPLOADTHING_APP_ID=your_uploadthing_app_id

# -----------------------------------------------------------------------------
# MONITORING (optional)
# -----------------------------------------------------------------------------

SENTRY_DSN=https://...@sentry.io/...
POSTHOG_KEY=phc_...
POSTHOG_HOST=https://app.posthog.com

{
  "name": "shipflow-ai",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @shipflow/db db:generate",
    "db:push": "pnpm --filter @shipflow/db db:push"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "turbo": "^2.0.4",
    "typescript": "^5.4.5"
  },
  "optionalDependencies": {
    "@next/swc-win32-x64-msvc": "^14.2.33"
  }
}

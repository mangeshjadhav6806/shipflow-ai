# =============================================================================
# ShipFlow AI — Local Development Environment
# =============================================================================
# This file is for LOCAL development only.
# Values here use the Docker Compose PostgreSQL configuration.
# Copy this file to .env.local (git-ignored) and adjust as needed.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE — Local Docker PostgreSQL
# -----------------------------------------------------------------------------

DATABASE_URL=postgresql://shipflow:shipflow_secret@localhost:5432/shipflow_db
DIRECT_URL=postgresql://shipflow:shipflow_secret@localhost:5432/shipflow_db

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------

NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# BETTER AUTH
# -----------------------------------------------------------------------------

BETTER_AUTH_SECRET=dev-secret-min-32-chars-change-in-prod-!!

GITHUB_CLIENT_ID=Ov23li...
GITHUB_CLIENT_SECRET=your_dev_github_secret

# -----------------------------------------------------------------------------
# AI PROVIDERS (use test/dev keys locally)
# -----------------------------------------------------------------------------

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# GITHUB APP
# -----------------------------------------------------------------------------

GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=dev_webhook_secret

# -----------------------------------------------------------------------------
# INNGEST (Local Dev Server)
# -----------------------------------------------------------------------------

INNGEST_EVENT_KEY=local
INNGEST_SIGNING_KEY=signkey-local

# -----------------------------------------------------------------------------
# PAYMENTS (Razorpay Test Mode)
# -----------------------------------------------------------------------------

RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_test_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=dev_razorpay_webhook_secret

# -----------------------------------------------------------------------------
# EMAIL (Resend Test Mode)
# -----------------------------------------------------------------------------

RESEND_API_KEY=re_...
EMAIL_FROM=noreply@shipflow.ai
